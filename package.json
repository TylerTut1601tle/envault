{
  "name": "envault",
  "version": "0.1.0",
  "description": "A CLI tool for managing and encrypting local .env files with team-sharing support via Git-compatible secrets.",
  "main": "dist/index.js",
  "bin": {
    "envault": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "keywords": ["env", "encryption", "cli", "dotenv", "secrets"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/jest": "^29.5.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"]
  }
}
